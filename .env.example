# Groq Llama configuration (required for intelligent planning)
GROQ_API_KEY=your_groq_api_key_here
MODEL_NAME=llama-3.3-70b-versatile

# MCP Toolbox endpoint used by agent/tools_client.py
MCP_BASE_URL=http://localhost:5000

# DB connection variables consumed by agent/tools.yaml
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/oracleforge
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=yelp_db
SQLITE_PATH=/absolute/path/to/sqlite.db
DUCKDB_PATH=/absolute/path/to/yelp_user.db

# Runtime safety controls
MAX_PROMPT_TOKENS=3500
MAX_TOOL_LOOPS=12
ORACLE_FORGE_MOCK_MODE=false
ORACLE_FORGE_ALLOW_MOCK_FALLBACK=false

# Evaluation defaults (optional)
DAB_DATASET=yelp
DAB_TRIALS_PER_QUERY=50
